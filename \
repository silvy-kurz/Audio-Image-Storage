  return AFI_FILE_OPEN_FAILED;
  }
  u8 master_riff_data[12];

  if (fread(master_riff_data, 1, 12, fp) < 12) {
    printf("File Read Failed\n");
    return AFI_FILE_OPEN_FAILED;
  }

  u32 riff_file_size;
  memcpy(&riff_file_size, master_riff_data + 4, 4);

  int chunk_count;
  get_chunk_count(fp, riff_file_size + 8, &chunk_count);
  
